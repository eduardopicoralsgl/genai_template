APP_ENV=local
LOG_LEVEL=INFO

#############################################
#            Default LLM config             #
#############################################
DEFAULT_MODEL=gpt-4.1-mini
DEFAULT_PROVIDER=openai

#############################################
#                 Langfuse                  #
#############################################
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

#############################################
#              Prompt Registry              #
#############################################
PROMPT_REGISTRY_BACKEND=fallback

#############################################
#               LLM providers               #
#############################################
## OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

## Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

## Anthropic
ANTHROPIC_API_KEY=

## Gemini
GEMINI_API_KEY=

## Gemini via Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=credentials/.project-vertexai-credentials.json
